# Supabase (client-safe — published to the browser bundle by design)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Apify Booli scraper (server-only)
APIFY_API_TOKEN=

# Anthropic — BRF financial extraction (Haiku 4.5).
# SERVER-ONLY: never prefix with NEXT_PUBLIC_; never commit a real key (.env* is gitignored).
# Source: console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=

# Discovery surface (Phases 9–12) feature flag / kill switch. Server-only.
# startDiscovery + the sweep route fail closed unless this is exactly "true".
# Legal go/no-go: GO (operator decision 2026-07-08); flag retained as runtime control.
DISCOVERY_ENABLED=
