# Supabase (client-safe — published to the browser bundle by design)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Apify Booli scraper (server-only)
APIFY_API_TOKEN=

# Anthropic — BRF financial extraction (Haiku 4.5).
# SERVER-ONLY: never prefix with NEXT_PUBLIC_; never commit a real key (.env* is gitignored).
# Source: console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=
